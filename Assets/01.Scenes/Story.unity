--- !u!114 &798518523
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 798518522}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1ec43c9ff82bcaf4fb434945d129e995, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueManager
  nameBox: {fileID: 9176297767512080860}
  textBox: {fileID: 6059918089376726206}
  dialogueObj: {fileID: 2193029588231266826}
  blinkerBtn: {fileID: 4763832747806315544}
  startDialogues:
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uB098\uB294 \uC790\uCE6D \uC624\uCEEC\uD2B8 \uD0D0\uD5D8\uAC00\uB2E4."
    soundType: 0
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uC624\uB298 \uCC3E\uC740 \uC774\uACF3, 'oo\uACE0\uB4F1\uD559\uAD50'\uB3C4
      \uB2E4\uB978 \uACF3\uB4E4 \uCC98\uB7FC \uADC0\uC2E0\uC774 \uC0B0\uB2E4\uB294
      \uC18C\uBB38\uC774 \uC788\uB2E4\uB358\uB370.."
    soundType: 0
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uD56D\uC0C1 \uADF8\uB7AC\uB358 \uAC83\uCC98\uB7FC \uB9C9\uC0C1
      \uB4E4\uC5B4\uAC00\uBA74 \uC544\uBB34\uC77C\uB3C4 \uC5C6\uACA0\uC9C0.."
    soundType: 16
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uBB38\uC740 \uC548 \uC7A0\uACA8\uC788\uACA0\uC9C0?? \uD55C\uBC88
      \uC5F4\uB9AC\uB098 \uBC00\uC5B4\uBD10\uC57C\uC9C0"
    soundType: 0
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uC751? \uC0DD\uAC01\uBCF4\uB2E4 \uC27D\uAC8C \uC5F4\uB9B4 \uAC83
      \uAC19... \uC5B4, \uC5B4\uC5B4?!"
    soundType: 19
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uBB50\uC57C.. \uB204\uAC00 \uC55E\uC5D0\uC11C \uB098\uB97C \uC7A1\uC544
      \uB2F9\uAE30\uB294 \uB290\uB08C\uC774\uC5C8\uC5B4.."
    soundType: 15
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uBB50\uC57C... \uC65C \uC548 \uC5F4\uB824! \uC57C! \uBC16\uC5D0
      \uB204\uAD6C \uC788\uC5B4?!"
    soundType: 17
  - speakerType: 1
    speakerName: ???
    dialogueText: "\uD788\uD788...\uC5EC\uAE30\uAE4C\uC9C0 \uC654\uC73C\uBA74, \uB098\uB791
      \uB180\uC544\uC57C\uC9C0?"
    soundType: 9
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uB204\uAD6C\uC57C! \uAC70\uAE30 \uB204\uAD6C \uC788\uC5B4? \uC7A5\uB09C\uCE58\uC9C0
      \uB9D0\uACE0 \uB2F9\uC7A5 \uB098\uC640!"
    soundType: 10
  - speakerType: 0
    speakerName: "\uB098"
    dialogueText: "\uC18C\uBB38\uC774 \uC0AC\uC2E4\uC774\uC5C8\uC5B4.. \uC5B4\uB5BB\uAC8C\uB4E0
      \uC5EC\uAE30\uC11C \uB098\uAC08 \uBC29\uBC95\uC744 \uCC3E\uC544\uC57C \uD574...!"
    soundType: 0
  typingSpeed: 0.05
  isTyping: 0
  textEnemyColor: {r: 0.45057723, g: 0.15138839, b: 0.509434, a: 1}
